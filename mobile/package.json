{
  "name": "mobile",
  "private": true,
  "version": "0.1.0",
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:no-devtools": "EXPO_UNSTABLE_HEADLESS=1 expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export --platform all",
    "doctor": "expo-doctor",
    "prebuild:android": "expo prebuild --clean --platform android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@clerk/expo": "^3.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@tanstack/react-query": "^5.68.0",
    "@twilio/voice-react-native-sdk": "^1.7.0",
    "expo": "~55.0.8",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.9",
    "expo-auth-session": "~55.0.9",
    "expo-contacts": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "papaparse": "^5.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "19.2.4",
    "typescript": "~5.9.2"
  }
}
