{
  "expo": {
    "name": "Aura",
    "slug": "aura-softphone",
    "scheme": "aura",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aura.softphone",
      "infoPlist": {
        "UIBackgroundModes": [
          "voip",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.aura.softphone",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "70b67a03-4315-4efb-94b0-f868dee41ef7"
      }
    },
    "plugins": [
      "@clerk/expo",
      "./plugins/withTwilioVoiceAndroid",
      "expo-dev-client",
      "expo-secure-store",
      "expo-notifications",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      "expo-asset"
    ]
  }
}
