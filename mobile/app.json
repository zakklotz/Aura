{
  "expo": {
    "name": "Aura",
    "slug": "aura-softphone",
    "scheme": "aura",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aura.softphone",
      "infoPlist": {
        "UIBackgroundModes": [
          "voip",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.aura.softphone",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "@clerk/expo",
      "./plugins/withTwilioVoiceAndroid",
      "expo-dev-client",
      "expo-secure-store",
      "expo-notifications",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "0d51fa55-de55-455a-8e09-fb170f69b78c"
      }
    },
    "owner": "zakklotz"
  }
}
